# ── Supabase (required for multi-user mode) ──────────────────────────────────

# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key (server-side only, never expose to client)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon/public key (fallback if service key not set)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase auth user ID (from auth.users table after signing up)
AGENT_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── iMessage Agent (required for: npm run imessage) ───────────────────────────

# Anthropic API key — Haiku for triage (~$0.001/run), Sonnet for replies (~$0.05/run)
ANTHROPIC_API_KEY=sk-ant-...

# ── Clay Sync (required for: npm run sync) ────────────────────────────────────

# Clay webhook URL for your D1 Networking table
# Find in Clay: open your table → Sources → Webhook → copy URL
CLAY_WEBHOOK_URL=https://api.clay.com/v3/sources/webhook/...

# ── iMessage Agent: optional integrations ────────────────────────────────────

# Perplexity — live web research on unknown contacts before generating replies
PERPLEXITY_API_KEY=pplx-...

# Slack — morning digest of pending questions and prospect gaps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# BMA prospect reply routing — routes prospect replies to a separate Slack channel
BMA_SLACK_WEBHOOK=https://hooks.slack.com/services/...
BMA_PROSPECT_KEYWORDS=bma,prospect,investor,bd,deal,fundraise

# Firestore — logs every sent/received text to imessage_interactions collection
FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_SA_KEY=/path/to/service-account.json

# Groq — free AI fallback if Anthropic credits run out
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Todoist — read/create tasks during triage
TODOIST_API_KEY=

# Loop Message — cloud webhook mode (deploy to Railway instead of running locally)
LOOP_API_KEY=
LOOP_SENDER_ID=
LOOP_SENDER_PHONE=+1xxxxxxxxxx
WEBHOOK_SECRET=

# ── Identity overrides ────────────────────────────────────────────────────────

# Override if your number changes (defaults to Caleb's)
CALEB_PHONE=+1xxxxxxxxxx
CALEB_EMAIL=you@gmail.com
